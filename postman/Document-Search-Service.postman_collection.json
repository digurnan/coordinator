{
  "info": {
    "name": "Document Search Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "tenantId", "value": "tenant_acme" },
    { "key": "documentId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Index Document",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('documentId', json.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Q1 Revenue Report\",\n  \"body\": \"Revenue increased 12% year over year in Q1 2026.\",\n  \"metadata\": { \"category\": \"finance\" }\n}"
        },
        "url": "{{baseUrl}}/documents"
      }
    },
    {
      "name": "Search Documents",
      "request": {
        "method": "GET",
        "header": [{ "key": "X-Tenant-ID", "value": "{{tenantId}}" }],
        "url": "{{baseUrl}}/search?q=revenue&tenant={{tenantId}}"
      }
    },
    {
      "name": "Get Document",
      "request": {
        "method": "GET",
        "header": [{ "key": "X-Tenant-ID", "value": "{{tenantId}}" }],
        "url": "{{baseUrl}}/documents/{{documentId}}"
      }
    },
    {
      "name": "Delete Document",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "X-Tenant-ID", "value": "{{tenantId}}" }],
        "url": "{{baseUrl}}/documents/{{documentId}}"
      }
    }
  ]
}
